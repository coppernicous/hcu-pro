{
  "manifest_version": 3,
  "name": "Campus USAT PRO",
  "description": "Mejora la apariencia y agrega nuevas funciones al Campus Virtual y Aula Virtual",
  "version": "18.20",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.usat.edu.pe/*",
    "*://usat.edu.pe/*",
    "https://coppernicous.github.io/*"
  ],
  "action": {
    "default_title": "Abrir Campus USAT PRO"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png",
    "256": "icon-256.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.usat.edu.pe/*",
        "*://usat.edu.pe/*",
        "*://coppernicous.github.io/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "homepage_url": "https://coppernicous.github.io/hcu-pro/site/"
}